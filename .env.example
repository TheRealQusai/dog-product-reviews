# ─── Site ────────────────────────────────────────────────────────
# Canonical URL used for SEO metadata, sitemap, and robots.txt.
# Must include protocol, no trailing slash.
NEXT_PUBLIC_SITE_URL=https://honestpawfinds.xyz

# Contact email shown on legal pages.
NEXT_PUBLIC_CONTACT_EMAIL=contact@honestpawfinds.xyz

# ─── Analytics (optional) ────────────────────────────────────────
# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX).
# Leave empty to disable analytics in development.
NEXT_PUBLIC_GA_ID=G-2DLCV70SY4

# ─── Affiliate (optional) ────────────────────────────────────────
# Default Amazon Associates tag appended to affiliate links.
NEXT_PUBLIC_AMAZON_TAG=honestpawfind-20
